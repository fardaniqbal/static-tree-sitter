# Don't do line ending conversions by default.  We'll specify eol
# conversions explicitly on a per-file-extension basis.
* -text

# Declare files that will always have CRLF or LF line endings on checkout.
*.sln text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.bash text eol=lf
*.sh text eol=lf
*.ksh text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.csh text eol=lf
*.md text eol=lf
*.txt text eol=lf
Makefile text eol=lf
makefile text eol=lf
*.mk text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.hpp text eol=lf
*.hxx text eol=lf
*.cs text eol=lf
*.java text eol=lf
*.jsf text eol=lf
*.jsp text eol=lf
*.jspf text eol=lf
*.js text eol=lf
*.ts text eol=lf
